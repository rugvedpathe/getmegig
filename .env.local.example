# Copy this file to .env.local for local development
# Add these same keys to Vercel: Project → Settings → Environment Variables

# ── Cloudinary (free at cloudinary.com) ──────────────────────────
# 1. Sign up free at cloudinary.com
# 2. Your cloud name is shown top-left of the dashboard
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# 3. Settings → Upload → Add upload preset → Signing Mode: Unsigned
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# ── Anthropic (for AI bio + pitch generation) ─────────────────────
# Get from: console.anthropic.com → API Keys
# ⚠️  For production, move AI calls to a serverless function
#     to keep this key off the client bundle
REACT_APP_ANTHROPIC_KEY=sk-ant-your-key-here
