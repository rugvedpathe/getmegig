# Copy this file to .env.local for local development
# Add these same keys to Vercel: Project → Settings → Environment Variables

# ── Clerk (authentication) ──────────────────────────────────────
# 1. Sign up free at clerk.com
# 2. Create a new application
# 3. Enable Google + Email/Password login methods
# 4. Copy keys from API Keys page
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# ── Clerk redirect URLs ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── MongoDB Atlas ────────────────────────────────────────────────
# 1. Create a free cluster at mongodb.com/atlas
# 2. Create a database user
# 3. Get connection string from Connect → Drivers
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/getmegig?retryWrites=true&w=majority

# ── Cloudinary (free at cloudinary.com) ──────────────────────────
# 1. Sign up free at cloudinary.com
# 2. Your cloud name is shown top-left of the dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# 3. Settings → Upload → Add upload preset → Signing Mode: Unsigned
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# ── Anthropic (for AI bio + pitch generation) ─────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
